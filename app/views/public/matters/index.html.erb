<% content_for(:title) { "Matters" } %>
<% content_for(:description) { "Browse #{current_jurisdiction.short_name} legislative matters, agenda files, official attachments, extracted document text, and source links." } %>
<% content_for(:robots) { "noindex,follow" } if @query.present? %>

<main class="newspaper-shell">
  <%= render "public/shared/topbar", active: :matters %>

  <header class="page-header inset-header">
    <p class="eyebrow">Official Records</p>
    <h1>Matters</h1>
    <p>Browse legislative files linked from recent <%= current_jurisdiction.short_name %> meetings.</p>
  </header>

  <% if @theme %>
    <p class="breadcrumb inset-panel">
      Showing matters tagged <strong><%= @theme_label %></strong>, primary-theme matters first.
      <%= link_to "View all matters", public_matters_path, class: "source-link" %>
    </p>
  <% end %>

  <%= form_with url: public_matters_path, method: :get, local: true, class: "search-form inset-panel" do |form| %>
    <%= form.label :q, "Search matters and extracted document text", for: "matter-filter-q" %>
    <div class="search-row">
      <%= form.search_field :q, id: "matter-filter-q", value: @query, placeholder: "Matter file, title, name, or document text" %>
      <%= form.label :theme, "Theme", for: "matter-filter-theme", class: "sr-only" %>
      <%= form.select :theme,
            options_for_select(Civic::ThemeTaxonomy.themes_for(current_jurisdiction).map { |theme| [ theme[:label], theme[:slug] ] }.sort_by(&:first), @theme),
            { include_blank: "Any theme" },
            id: "matter-filter-theme" %>
      <%= form.submit "Search" %>
      <% if @query.present? || @theme %>
        <%= link_to "Clear", public_matters_path, class: "button-secondary" %>
      <% end %>
    </div>
  <% end %>

  <% if @matters.any? %>
    <section class="record-list inset-panel" aria-label="Matters">
      <% @matters.each do |matter| %>
        <article class="record-row">
          <div>
            <h2><%= link_to matter.display_name, public_matter_path(matter) %></h2>
            <% if matter.descriptive_title.present? %>
              <p><%= matter.descriptive_title %></p>
            <% end %>
            <p class="record-meta">
              <%= [matter.matter_type_name, matter.matter_status_name, matter.body_name].compact_blank.join(" / ") %>
            </p>
            <% primary_theme = matter.themes.detect { |theme| theme.rank == 1 } %>
            <% if primary_theme %>
              <div class="tags">
                <%= link_to primary_theme.label, public_matters_path(theme: primary_theme.theme_slug), class: "pill green" %>
              </div>
            <% end %>
            <% if (document_matches = @document_matches_by_matter_id[matter.id]).present? %>
              <div class="document-search-hits">
                <p>Extracted document text matches</p>
                <ul>
                  <% document_matches.first(2).each do |match| %>
                    <li>
                      <%= link_to match.matter_attachment.name, public_matter_path(matter, anchor: "attachment-#{match.matter_attachment.id}") %>
                      <span><%= document_search_snippet(match) %></span>
                    </li>
                  <% end %>
                </ul>
              </div>
            <% end %>
          </div>
          <dl class="record-facts">
            <div>
              <dt>Agenda date</dt>
              <dd><%= matter.agenda_date || "Unknown" %></dd>
            </div>
            <div>
              <dt>Attachments</dt>
              <dd><%= matter.attachments.size %></dd>
            </div>
          </dl>
        </article>
      <% end %>
    </section>
  <% elsif @query.present? %>
    <p class="empty-state inset-panel">No matters matched "<%= @query %>".</p>
  <% else %>
    <p class="empty-state inset-panel">No matters have been ingested yet.</p>
  <% end %>

  <%= render "public/shared/footer" %>
</main>
