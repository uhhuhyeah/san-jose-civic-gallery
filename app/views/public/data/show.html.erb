<% content_for(:title) { "Data Health" } %>
<% content_for(:description) { "Review #{current_jurisdiction.site_title} ingestion freshness, record counts, attachment processing, extraction coverage, and source-data reliability." } %>
<% content_for :body_class, "atlas-shell" %>
<% content_for :head do %>
  <%= stylesheet_link_tag "atlas", "data-turbo-track": "reload" %>
<% end %>

<main class="atlas-wrap" id="main">
  <%= render "public/shared/atlas_topbar", active: :data %>

  <header class="atlas-data-header">
    <p class="atlas-eyebrow">Transparency</p>
    <h1>Data Health</h1>
    <p>What we've ingested from <%= current_jurisdiction.ingestion_source_label %> and how reliable the processing pipeline has been.</p>
  </header>

  <% if @snapshot.empty? %>
    <section class="atlas-data-empty">
      <h2>No data ingested yet</h2>
      <p>
        Once an operator runs ingestion (for example,
        <code>bin/rails ingestion:sync_recent_events</code>),
        this page will fill in with current counts, freshness, and
        reliability rates.
      </p>
    </section>
  <% else %>
    <%# ---------- FRESHNESS BANNER ---------- %>
    <%
      freshness_variant = case @snapshot.freshness_level
                         when :green then nil
                         when :amber then "amber"
                         when :red then "red"
                         else "unknown"
                         end
      freshness_classes = [ "atlas-data-freshness", ("atlas-data-freshness--#{freshness_variant}" if freshness_variant) ].compact.join(" ")
    %>
    <section class="<%= freshness_classes %>" aria-label="Ingestion freshness">
      <span class="atlas-data-freshness-dot" aria-hidden="true"></span>
      <span class="atlas-data-freshness-status">
        <% if @snapshot.last_synced_at %>
          Synced <%= time_ago_in_words(@snapshot.last_synced_at) %> ago
        <% else %>
          Last sync unknown
        <% end %>
      </span>
      <span class="atlas-data-freshness-source">Source: <%= current_jurisdiction.ingestion_source_label %></span>
    </section>

    <%# ---------- WHAT WE HAVE ---------- %>
    <section class="atlas-data-section">
      <%= render "public/shared/atlas_section_heading",
                 title: "What",
                 em: "we have",
                 label: "Record counts" %>
      <dl class="atlas-data-stats">
        <div class="atlas-data-stat">
          <dt>Matters</dt>
          <dd>
            <strong><%= number_with_delimiter(@snapshot.matter_count) %></strong>
            <% if (range = @snapshot.matter_date_range) %>
              <span>covering <%= range.first.iso8601 %> — <%= range.last.iso8601 %></span>
            <% end %>
          </dd>
        </div>
        <div class="atlas-data-stat">
          <dt>Events</dt>
          <dd>
            <strong><%= number_with_delimiter(@snapshot.event_count) %></strong>
            <% bodies = @snapshot.events_by_body %>
            <% if bodies[:top].any? %>
              <span>
                <%= bodies[:top].map { |body, count| "#{body} (#{number_with_delimiter(count)})" }.join(", ") %><%
                  if bodies[:other_body_count].positive? %>, <%= pluralize(bodies[:other_body_count], "other") %> (<%= number_with_delimiter(bodies[:other_count]) %>)<% end %>
              </span>
            <% end %>
          </dd>
        </div>
        <div class="atlas-data-stat">
          <dt>Attachments</dt>
          <dd>
            <strong><%= number_with_delimiter(@snapshot.attachment_count) %></strong>
          </dd>
        </div>
        <% if (matter = @snapshot.most_recent_matter) %>
          <div class="atlas-data-stat">
            <dt>Most recent matter</dt>
            <dd>
              <strong><%= matter.matter_file %></strong>
              <span>agenda <%= matter.agenda_date.iso8601 %></span>
            </dd>
          </div>
        <% end %>
      </dl>
    </section>

    <%# ---------- FRESHNESS DETAIL ---------- %>
    <section class="atlas-data-section">
      <%= render "public/shared/atlas_section_heading",
                 title: "How",
                 em: "fresh",
                 label: "Sync recency" %>
      <dl class="atlas-data-stats">
        <div class="atlas-data-stat">
          <dt>Last sync</dt>
          <dd>
            <% if @snapshot.last_synced_at %>
              <strong><%= time_ago_in_words(@snapshot.last_synced_at) %> ago</strong>
              <span><%= @snapshot.last_synced_at.utc.iso8601 %></span>
            <% else %>
              <strong>—</strong>
            <% end %>
          </dd>
        </div>
        <div class="atlas-data-stat">
          <dt>Synced in the last 24 hours</dt>
          <dd>
            <strong><%= pluralize(@snapshot.matters_synced_since(1.day.ago), "matter") %></strong>
            <span class="atlas-data-stat-sep">·</span>
            <strong><%= pluralize(@snapshot.events_synced_since(1.day.ago), "event") %></strong>
          </dd>
        </div>
        <div class="atlas-data-stat">
          <dt>Synced in the last 7 days</dt>
          <dd>
            <strong><%= pluralize(@snapshot.matters_synced_since(7.days.ago), "matter") %></strong>
            <span class="atlas-data-stat-sep">·</span>
            <strong><%= pluralize(@snapshot.events_synced_since(7.days.ago), "event") %></strong>
          </dd>
        </div>
      </dl>
    </section>

    <%# ---------- RELIABILITY (RATE METERS) ---------- %>
    <section class="atlas-data-section">
      <%= render "public/shared/atlas_section_heading",
                 title: "How",
                 em: "reliable",
                 label: "Pipeline coverage" %>
      <p class="atlas-data-section-note">
        The attachment rates are out of <%= number_with_delimiter(@snapshot.import_eligible_count) %>
        current attachments with a source link, so they reflect end-to-end
        pipeline coverage rather than per-stage success. Theme classification is
        measured across all matters, and meeting summaries across meetings with
        an itemized agenda on file (some meetings, such as many advisory-body
        sessions, have no itemized agenda in our data and are not summarized).
      </p>
      <%= render "rate",
        label: "Attachments with imported source files",
        numerator: @snapshot.imported_count,
        denominator: @snapshot.import_eligible_count %>
      <%= render "rate",
        label: "Attachments with extracted text",
        numerator: @snapshot.pdf_extracted_count,
        denominator: @snapshot.import_eligible_count %>
      <%= render "rate",
        label: "Attachments with AI summaries",
        numerator: @snapshot.summarized_count,
        denominator: @snapshot.import_eligible_count %>
      <%= render "rate",
        label: "Matters classified into themes",
        numerator: @snapshot.theme_classified_count,
        denominator: @snapshot.matter_count %>
      <%= render "rate",
        label: "Meetings with AI summaries (of those with an itemized agenda)",
        numerator: @snapshot.event_summarized_count,
        denominator: @snapshot.event_summary_eligible_count %>
    </section>

    <%# ---------- RECONCILIATION ---------- %>
    <section class="atlas-data-section">
      <%= render "public/shared/atlas_section_heading",
                 title: "What",
                 em: "fell out",
                 label: "Removed by source · last 30 days" %>
      <dl class="atlas-data-stats">
        <div class="atlas-data-stat">
          <dt>Events removed by source</dt>
          <dd><strong><%= number_with_delimiter(@snapshot.events_removed_since(30.days.ago)) %></strong></dd>
        </div>
        <div class="atlas-data-stat">
          <dt>Attachments removed by source</dt>
          <dd><strong><%= number_with_delimiter(@snapshot.attachments_removed_since(30.days.ago)) %></strong></dd>
        </div>
      </dl>
    </section>
  <% end %>

  <%# ---------- ABOUT + SOURCES ---------- %>
  <section class="atlas-data-about" aria-label="About this page">
    <h3>About this page</h3>
    <p>
      This page reports what's been ingested from <%= current_jurisdiction.ingestion_source_label %> and how
      complete the processing pipeline has been.
    </p>
    <%= render "public/data/sources_#{current_jurisdiction.slug}" %>
    <p>
      Read more about the project:
      <a href="https://github.com/uhhuhyeah/san-jose-civic-gallery/blob/main/docs/architecture.md" rel="noopener">architecture</a>
      and
      <a href="https://github.com/uhhuhyeah/san-jose-civic-gallery/blob/main/docs/generated-summaries.md" rel="noopener">generated summaries</a>
      documentation.
    </p>
  </section>

  <p class="atlas-data-ai-note">
    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M12 3 2 21h20L12 3Z"></path>
      <path d="M12 9v5"></path>
      <circle cx="12" cy="17" r="1" fill="currentColor"></circle>
    </svg>
    Generated summaries are AI-produced and may contain errors. Always review the official source document before relying on them.
  </p>

  <%= render "public/shared/atlas_footer" %>
</main>
