<%# Atlas facts strip — horizontal mono-caps facts header.
    Locals (required):
      facts: Array of Hashes. Each hash MUST include `dt:` and `dd:`; may also
             include `class:` (string applied to the <dd>, e.g. "mono" or
             "unknown") and `href:` (URL — if present, the dd content renders
             as a link). All values pass through ERB default escaping.
%>
<dl class="atlas-facts-strip" style="--cols: <%= facts.length %>">
  <% facts.each do |fact| %>
    <div>
      <dt><%= fact[:dt] %></dt>
      <dd class="<%= fact[:class] %>">
        <% if fact[:href].present? %>
          <%= link_to fact[:dd], fact[:href] %>
        <% else %>
          <%= fact[:dd] %>
        <% end %>
      </dd>
    </div>
  <% end %>
</dl>
