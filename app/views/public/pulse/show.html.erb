<% content_for(:description) { "#{current_jurisdiction.site_title} shows which civic themes #{current_jurisdiction.governing_bodies_phrase} are focused on, what is heating up, and the latest official agenda records, matters, and documents." } %>
<% content_for(:robots) { "noindex,follow" } if @body_name.present? %>

<main class="newspaper-shell pulse-page">
  <%= render "public/shared/topbar", active: :pulse %>

  <section class="front-intro">
    <h1><%= current_jurisdiction.site_title %></h1>
  </section>

  <nav class="topic-bar" aria-label="Browse matters by topic">
    <span class="topic-bar-label">Browse by theme</span>
    <div class="topic-bar-chips">
      <% Civic::ThemeTaxonomy.themes_for(current_jurisdiction).sort_by { |theme| theme[:label] }.each do |theme| %>
        <%= link_to theme[:label], public_matters_path(theme: theme[:slug]), class: "pill" %>
      <% end %>
    </div>
  </nav>

  <%# Main content: Pulse selector, changes, decisions and meetings (left);
      source-record counts and about (right). Two independent columns. %>
  <section class="newspaper-body">
    <div>
      <%= form_with url: root_path, method: :get, local: true, class: "search-form" do |form| %>
        <div class="section-title">
          <h2>The Civic Gallery <em>Pulse</em></h2>
          <span>Themes trending across agendas this quarter</span>
        </div>
        <p class="data-section-note">
          The <em>"Pulse"</em> shows which themes <%= current_jurisdiction.governing_bodies_phrase %> have been focused on
          this quarter and what is heating up, alongside the latest official
          agenda materials.
        </p>
        <p class="data-section-note">
          Themes are derived from AI tagging of matters and
          are assistive, not official.
        </p>
        <%= form.label :body_name, "Show themes for", for: "pulse-body-name" %>
        <div class="search-row">
          <%= form.select :body_name,
            options_for_select([ [ current_jurisdiction.all_bodies_option_label, "" ] ] + @body_options.map { |body| [ body, body ] }, @body_name),
            {},
            id: "pulse-body-name",
            aria: { label: "Filter themes by body" } %>
          <%= form.submit "Update" %>
          <% if @body_name.present? %>
            <%= link_to current_jurisdiction.view_all_scope_label, root_path, class: "button-secondary" %>
          <% end %>
        </div>
      <% end %>

      <% scope_label = @body_name.presence || current_jurisdiction.all_scope_label %>
      <% if @heating_up.empty? %>
        <div class="section-title">
          <h2>Pulse Changes <span class="subtle">&middot; <%= scope_label %></span></h2>
          <span>More than last quarter, per meeting</span>
        </div>
        <div class="card">
          <article class="item">
            <h3 class="item-title">Not enough activity yet</h3>
            <p>
              There are not enough tagged agenda appearances in this window
              <% if @body_name.present? %>for <%= @body_name %> <% end %>to show a
              pulse. Try viewing <%= current_jurisdiction.all_scope_label.downcase %>, or check back as more meetings are
              ingested.
            </p>
          </article>
        </div>
      <% else %>
        <div class="section-title">
          <h2>Pulse Changes <span class="subtle">&middot; <%= scope_label %></span></h2>
          <span>More than last quarter, per meeting</span>
        </div>
        <div class="card">
          <% @heating_up.each do |stat| %>
            <article class="item">
              <h3 class="item-title"><%= link_to stat.label, public_matters_path(theme: stat.slug) %></h3>
              <div class="tags">
                <% if stat.surging %>
                  <span class="pill gold">New this quarter</span>
                <% else %>
                  <span class="pill green">&#9650; <%= ((stat.lift - 1) * 100).round %>% vs last quarter</span>
                <% end %>
                <span class="pill"><%= pluralize(stat.current_appearances, "appearance") %> this quarter</span>
              </div>
            </article>
          <% end %>
        </div>
      <% end %>

      <% if @recent_decisions.any? %>
        <div class="section-title">
          <h2>What's being decided</h2>
          <span>Recent matters, with generated summaries</span>
        </div>
        <div class="card">
          <% @recent_decisions.each do |matter| %>
            <% preview = matter_summary_preview(matter) %>
            <% next unless preview %>
            <% _attachment, summary = preview %>
            <% primary_theme = matter.themes.detect { |theme| theme.rank == 1 } %>
            <article class="item">
              <h3 class="item-title">
                <%= link_to public_matter_path(matter) do %>
                  <%= matter.display_name %><% if matter.descriptive_title && matter.descriptive_title != matter.display_name %> &middot; <%= matter.descriptive_title %><% end %>
                <% end %>
              </h3>
              <div class="tags">
                <% if primary_theme %>
                  <span class="pill green"><%= primary_theme.label %></span>
                <% end %>
                <% if matter.body_name.present? %>
                  <span class="pill"><%= matter.body_name %></span>
                <% end %>
              </div>
              <p><%= truncate(summary.squish, length: 220, separator: " ") %></p>
            </article>
          <% end %>
          <p class="card-note">Generated summaries are assistive, not official.</p>
        </div>
      <% end %>

      <div class="section-title meetings-title" id="meetings">
        <h2>Recent Meetings</h2>
        <span>Official source events</span>
      </div>
      <div class="compact-list">
        <% if @events.any? %>
          <% @events.each do |event| %>
            <article class="meeting-row">
              <time class="meeting-date" datetime="<%= event.event_date %>">
                <span><%= event.event_date.strftime("%b") %></span>
                <strong><%= event.event_date.day %></strong>
                <small><%= event.event_date.year %></small>
              </time>
              <div>
                <h3><%= link_to event.listing_title, public_event_path(event) %></h3>
                <p><%= event.body_name.presence || "Unknown body" %></p>
              </div>
              <div class="meeting-status">
                <span>Agenda: <%= event.agenda_status_name.presence || "Unknown" %></span>
                <span>Minutes: <%= event.minutes_status_name.presence || "Unknown" %></span>
              </div>
            </article>
          <% end %>
        <% else %>
          <p>No events have been ingested yet.</p>
        <% end %>
      </div>
    </div>

    <aside class="mini-stack" aria-label="Site overview">
      <div class="mini-card">
        <span class="subtle">Current source records</span>
        <strong><%= pluralize(@stats.fetch(:meetings), "meeting") %>, <%= pluralize(@stats.fetch(:agenda_items), "agenda item") %></strong>
        <%= link_to "View meeting calendar", public_meetings_path, class: "source-link" %>
      </div>
      <div class="mini-card">
        <span class="subtle">Linked matters</span>
        <strong><%= pluralize(@stats.fetch(:matters), "matter") %>, <%= pluralize(@stats.fetch(:attachments), "attachment") %></strong>
        <%= link_to "Browse official matters", public_matters_path, class: "source-link" %>
      </div>
      <div class="mini-card">
        <span class="subtle">Document processing</span>
        <strong><%= pluralize(@stats.fetch(:imported_files), "file") %> imported, <%= pluralize(@stats.fetch(:extracted_texts), "text extraction") %></strong>
        <span class="source-link">Source files stay separate from extracted text</span>
      </div>
      <div class="mini-card">
        <span class="subtle">About <%= current_jurisdiction.site_title %></span>
        <p>
          <strong><%= current_jurisdiction.site_title %></strong> is a free, open-source intelligence
          layer over <%= current_jurisdiction.civic_subject %>'s public records.
        </p>
        <p>
          Every meeting agenda and matter is ingested, tagged, and summarized so residents
          can cut through the noise and follow the topics they care about.
        </p>
        <p>The official records remain the source of truth: this site is a tool to help you research,
          understand, and ask better questions of your elected officials.
        </p>
        <p>
          Browse by <%= link_to 'meeting', public_meetings_path %>, browse by <%= link_to 'topic', public_matters_path %>, or search across both.
        </p>
      </div>
    </aside>
  </section>

  <%= render "public/shared/footer" %>
</main>
