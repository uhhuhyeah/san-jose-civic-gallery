<% content_for(:title) { "Meetings" } %>
<% content_for(:description) { "Browse #{current_jurisdiction.short_name} public meetings by month, body, agenda item, linked matter, and official source record." } %>
<% content_for(:robots) { "noindex,follow" } if @query.present? %>
<% content_for :body_class, "atlas-shell" %>
<% content_for :head do %>
  <%= stylesheet_link_tag "atlas", "data-turbo-track": "reload" %>
<% end %>

<%
  filter_active = @query.present? || @body_name.present?
  prev_month_param = (@month - 1.month).strftime("%Y-%m")
  next_month_param = (@month + 1.month).strftime("%Y-%m")
%>

<main class="atlas-wrap" id="main">
  <%= render "public/shared/atlas_topbar", active: :meetings %>

  <nav class="atlas-crumbs" aria-label="Breadcrumb">
    <span>All meetings</span>
    <span class="atlas-crumbs-sep">/</span>
    <span><%= @month.strftime("%B %Y") %></span>
    <% if @body_name.present? %>
      <span class="atlas-crumbs-sep">/</span>
      <span><%= @body_name %></span>
    <% end %>
    <% if @query.present? %>
      <span class="atlas-crumbs-sep">/</span>
      <span>"<%= @query %>"</span>
    <% end %>
  </nav>

  <%# ---------- PAGE HEADER ---------- %>
  <header class="atlas-meetings-header">
    <p class="atlas-eyebrow">Official Records</p>
    <h1>Meetings</h1>
    <p class="atlas-meetings-header-lede">Use meeting agendas as an entry point into what <%= current_jurisdiction.civic_subject %> is talking about this month.</p>
  </header>

  <%# ---------- MONTH NAV ---------- %>
  <nav class="atlas-meetings-monthnav" aria-label="Month navigation">
    <%= link_to "← Previous month", public_meetings_path(month: prev_month_param, q: @query.presence, body_name: @body_name.presence) %>
    <strong><%= @month.strftime("%B %Y") %></strong>
    <%= link_to "Next month →", public_meetings_path(month: next_month_param, q: @query.presence, body_name: @body_name.presence) %>
  </nav>

  <% if @body_name.present? %>
    <p class="atlas-meetings-banner">
      Showing meetings of <strong><%= @body_name %></strong>.
      <%= link_to "View all bodies", public_meetings_path(month: @month.strftime("%Y-%m")), class: "atlas-meetings-banner-clear" %>
    </p>
  <% end %>

  <%# ---------- FILTER FORM ---------- %>
  <%= form_with url: public_meetings_path, method: :get, local: true, class: "atlas-meetings-filter", role: "search" do |form| %>
    <%= form.hidden_field :year, value: @month.year %>
    <%= form.hidden_field :month_number, value: @month.month %>
    <%= form.label :q, "Search meetings, agenda items, and linked matters", for: "meeting-filter-q" %>
    <div class="atlas-meetings-filter-row">
      <%= form.search_field :q,
        id: "meeting-filter-q",
        value: @query,
        placeholder: "Meeting title, agenda item, matter file, or topic",
        autocomplete: "off" %>
      <%= form.label :body_name, "Body", for: "meeting-filter-body", class: "sr-only" %>
      <%= form.select :body_name,
        options_for_select([ [ "All bodies", "" ] ] + @body_options.map { |body| [ body, body ] }, @body_name),
        {},
        id: "meeting-filter-body",
        aria: { label: "Filter by body" } %>
      <%= form.submit "Search" %>
      <% if filter_active %>
        <%= link_to "Clear", public_meetings_path(month: @month.strftime("%Y-%m")), class: "atlas-meetings-filter-clear" %>
      <% end %>
    </div>
  <% end %>

  <%# ---------- RESULTS ---------- %>
  <% if @events.any? %>
    <p class="atlas-meetings-count">
      <strong><%= number_with_delimiter(@events.length) %></strong>
      <%= "meeting".pluralize(@events.length) %>
      <% if @body_name.present? %>· <%= @body_name %><% end %>
      <% if @query.present? %>· matching "<%= @query %>"<% end %>
    </p>
    <section class="atlas-meetings-results" aria-label="Meetings">
      <% @events.each do |event| %>
        <% linked_items = event.event_items.select(&:matter) %>
        <% attachment_count = linked_items.sum { |item| item.matter.attachments.size } %>
        <% agenda_status = event.agenda_status_name.presence %>
        <% minutes_status = event.minutes_status_name.presence %>
        <% remaining = event.event_items.size - 3 %>
        <article class="atlas-meeting-row">
          <%= render "public/shared/atlas_date_plate",
                     date: event.event_date,
                     size: :md,
                     aria_label: "Meeting date #{event.event_date.strftime('%-d %B %Y')}" %>

          <div class="atlas-meeting-row-body">
            <h2><%= link_to event.listing_title, public_event_path(event) %></h2>
            <div class="atlas-meeting-row-meta">
              <% if event.body_name.present? %>
                <span class="atlas-meeting-row-body-name"><%= event.body_name %></span>
              <% end %>
              <% if event.location_name.present? %>
                <span><%= event.location_name %></span>
              <% end %>
              <% if agenda_status %>
                <% variant = agenda_status.downcase == "final" ? "sage" : "heat" %>
                <span class="atlas-chip atlas-chip--<%= variant %>">Agenda · <%= agenda_status %></span>
              <% end %>
              <% if minutes_status %>
                <% variant = minutes_status.downcase == "final" ? "sage" : "heat" %>
                <span class="atlas-chip atlas-chip--<%= variant %>">Minutes · <%= minutes_status %></span>
              <% end %>
            </div>

            <% if event.event_items.any? %>
              <div class="atlas-meeting-row-preview">
                <p class="atlas-meeting-row-preview-label">Agenda items</p>
                <ul>
                  <% event.event_items.first(3).each do |item| %>
                    <li>
                      <% if item.matter %>
                        <%= link_to item.display_name, public_matter_path(item.matter) %>
                      <% else %>
                        <span><%= item.display_name %></span>
                      <% end %>
                      <% if item.title.present? && item.title != item.display_name %>
                        <span><%= item.title %></span>
                      <% end %>
                    </li>
                  <% end %>
                </ul>
                <% if remaining.positive? %>
                  <%= link_to "+#{pluralize(remaining, "more agenda item")}", public_event_path(event), class: "atlas-meeting-row-preview-more" %>
                <% end %>
              </div>
            <% end %>
          </div>

          <dl class="atlas-meeting-row-facts">
            <div>
              <dt>Date</dt>
              <dd><%= event.event_date.strftime("%d %b") %></dd>
            </div>
            <div>
              <dt>Matters</dt>
              <dd><%= linked_items.size %></dd>
            </div>
            <div>
              <dt>Attachments</dt>
              <dd><%= attachment_count %></dd>
            </div>
            <div>
              <dt>Items</dt>
              <dd><%= event.event_items.size %></dd>
            </div>
          </dl>
        </article>
      <% end %>
    </section>
  <% elsif filter_active %>
    <p class="atlas-meetings-empty">No meetings matched the selected filters for <%= @month.strftime("%B %Y") %>.</p>
  <% else %>
    <p class="atlas-meetings-empty">No meetings have been ingested for <%= @month.strftime("%B %Y") %>.</p>
  <% end %>

  <%= render "public/shared/atlas_footer" %>
</main>
